{
  "name": "cite",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run --bun astro dev",
    "start": "bun run --bun astro dev",
    "check": "bunx tsgo --noEmit && bun run --bun astro check",
    "format": "oxfmt --ignore-path .oxfmtignore --write .",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "build": "bun run --bun astro check && bun run --bun astro build",
    "preview": "bun run --bun astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/react": "6.0.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vercel/config": "^0.2.1",
    "astro": "7.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "@astrojs/markdown-remark": "7.2.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260604.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.68.0",
    "tw-animate-css": "^1.4.0"
  },
  "engines": {
    "bun": "1.x"
  },
  "packageManager": "bun@1.3.0"
}
